generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model acc_accountcategory {
  accountcategoryid         Int                   @id @default(autoincrement())
  accountcategorycode       String?               @db.VarChar(20)
  accountcategoryname       String?               @db.VarChar(200)
  accountcategorynamear     String?               @db.VarChar(200)
  balancesheettypecd        Int
  isactive                  Boolean               @default(true)
  companyid                 Int?
  createdby                 Int?
  createddate               DateTime?             @default(now()) @db.Timestamp(6)
  modifiedby                Int?
  modifieddate              DateTime?             @db.Timestamp(6)
  parentaccountcategoryid   Int?
  gen_lookup                gen_lookup            @relation(fields: [balancesheettypecd], references: [lookupid], onDelete: NoAction, onUpdate: NoAction, map: "fk_accountcategory_balancesheettype")
  gen_company               gen_company?          @relation(fields: [companyid], references: [companyid], onDelete: NoAction, onUpdate: NoAction, map: "fk_accountcategory_company")
  acc_accountcategory       acc_accountcategory?  @relation("acc_accountcategoryToacc_accountcategory", fields: [parentaccountcategoryid], references: [accountcategoryid], onDelete: NoAction, onUpdate: NoAction, map: "fk_accountcategory_parent")
  other_acc_accountcategory acc_accountcategory[] @relation("acc_accountcategoryToacc_accountcategory")
  acc_ledger                acc_ledger[]

  @@unique([companyid, accountcategorycode], map: "uq_acc_accountcategory_company_code")
}

model acc_accountposting {
  accountpostingid                                               Int           @id @default(autoincrement())
  sourcetranstypecd                                              Int
  sourcetranssubtypecd                                           Int?
  sourcetransno                                                  String        @db.VarChar(40)
  sourcetransid                                                  Int
  ledgerid                                                       Int
  description                                                    String?
  reference                                                      String?
  currencyid                                                     Int?
  exrate                                                         Decimal?      @db.Decimal(14, 4)
  amountdebit                                                    Decimal?      @db.Decimal(14, 4)
  amountcredit                                                   Decimal?      @db.Decimal(14, 4)
  fcamountdebit                                                  Decimal?      @db.Decimal(14, 4)
  fcamountcredit                                                 Decimal?      @db.Decimal(14, 4)
  remarks                                                        String?
  isdeleted                                                      Boolean       @default(false)
  deletedby                                                      Int?
  deleteddate                                                    DateTime?     @db.Timestamp(6)
  companyid                                                      Int?
  branchid                                                       Int?
  createdby                                                      Int?
  createddate                                                    DateTime?     @default(now()) @db.Timestamp(6)
  modifiedby                                                     Int?
  modifieddate                                                   DateTime?     @db.Timestamp(6)
  postingtypecd                                                  Int?
  gen_branch                                                     gen_branch?   @relation(fields: [branchid], references: [branchid], onDelete: NoAction, onUpdate: NoAction, map: "fk_aposting_branch")
  gen_company                                                    gen_company?  @relation(fields: [companyid], references: [companyid], onDelete: NoAction, onUpdate: NoAction, map: "fk_aposting_company")
  gen_currency                                                   gen_currency? @relation(fields: [currencyid], references: [currencyid], onDelete: NoAction, onUpdate: NoAction, map: "fk_aposting_currency")
  acc_ledger                                                     acc_ledger    @relation(fields: [ledgerid], references: [ledgerid], onDelete: NoAction, onUpdate: NoAction, map: "fk_aposting_ledger")
  gen_lookup_acc_accountposting_postingtypecdTogen_lookup        gen_lookup?   @relation("acc_accountposting_postingtypecdTogen_lookup", fields: [postingtypecd], references: [lookupid], onDelete: NoAction, onUpdate: NoAction, map: "fk_aposting_postingtype")
  gen_lookup_acc_accountposting_sourcetranssubtypecdTogen_lookup gen_lookup?   @relation("acc_accountposting_sourcetranssubtypecdTogen_lookup", fields: [sourcetranssubtypecd], references: [lookupid], onDelete: NoAction, onUpdate: NoAction, map: "fk_aposting_transsubtype")
  gen_lookup_acc_accountposting_sourcetranstypecdTogen_lookup    gen_lookup    @relation("acc_accountposting_sourcetranstypecdTogen_lookup", fields: [sourcetranstypecd], references: [lookupid], onDelete: NoAction, onUpdate: NoAction, map: "fk_aposting_transtype")
}

model acc_accountpostinglog {
  accountpostinglogid Int       @id @default(autoincrement())
  sourceid            Int
  sourcetype          Int
  requestmetadata     Json?
  responsemetadata    Json?
  status              Int
  retrycount          Int       @default(0)
  createdby           Int?
  createddate         DateTime? @default(now()) @db.Timestamp(6)
  modifiedby          Int?
  modifieddate        DateTime? @db.Timestamp(6)

  @@index([createddate], map: "ix_acc_accountpostinglog_createddate")
  @@index([sourceid, sourcetype], map: "ix_acc_accountpostinglog_source")
  @@index([status], map: "ix_acc_accountpostinglog_status")
}

